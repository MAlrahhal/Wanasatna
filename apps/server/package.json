{
  "name": "@wanasatna/server",
  "version": "0.1.0",
  "private": true,
  "description": "Wanasatna real-time API and Socket.IO server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
