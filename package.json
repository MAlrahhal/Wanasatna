{
  "name": "wanasatna",
  "private": true,
  "version": "0.1.0",
  "description": "Wanasatna — Arabic-first browser-based multiplayer party games platform",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter=./apps/* run dev",
    "build": "pnpm --recursive --filter=./apps/* run build",
    "lint": "pnpm --recursive run lint",
    "typecheck": "pnpm --recursive run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9"
  }
}
